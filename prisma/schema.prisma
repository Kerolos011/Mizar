generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum ProductMediaType {
  IMAGE
  VIDEO
}

enum ProductStatus {
  DRAFT
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum ProductType {
  SIMPLE
  VARIABLE
  DIGITAL
  SERVICE
  BUNDLE
  SUBSCRIPTION
}

enum ProductVariantStatus {
  ACTIVE
  HIDDEN
  OUT_OF_STOCK
  DISABLED
}

enum InventoryPolicy {
  STOP_WHEN_OUT
  CONTINUE_SELLING
}

enum MediaSource {
  UPLOAD
  URL
  YOUTUBE
  VIMEO
}

enum ProductAttachmentType {
  PDF
  MANUAL
  WARRANTY
  INSTALLATION
  CATALOG
  OTHER
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
  SPAM
}

enum UserRole {
  SUPER_ADMIN
  MERCHANT
  CUSTOMER
}

enum Gender {
  MALE
  FEMALE
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum StoreTemplate {
  MIZAR_MODERN
  LUXE_NOIR
  SOFT_BOUTIQUE
  BAZAAR_CARDS
  TECH_MINIMAL

  GENERAL
  FASHION
  PERFUMES_BEAUTY
  ACCESSORIES
  HANDMADE
  HOME_PRODUCTS
  FOOD_BEVERAGE
  ELECTRONICS
}

enum StoreStatus {
  OPEN
  CLOSED
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  YOUTUBE
  X
  LINKEDIN
  SNAPCHAT
  TELEGRAM
  PINTEREST
  WHATSAPP
  MESSENGER
}

enum PaymentMethodType {
  CASH_ON_DELIVERY
  BANK_TRANSFER
  VODAFONE_CASH
  INSTAPAY
  VISA
  MASTERCARD
  APPLE_PAY
  GOOGLE_PAY
  MEEZA
}

enum StorePolicyType {
  ABOUT_US
  PRIVACY_POLICY
  TERMS_CONDITIONS
  SHIPPING_POLICY
  RETURN_POLICY
  EXCHANGE_POLICY
  REFUND_POLICY
  FAQ
  CAREERS
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model Store {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  category  String
  theme     String   @default("red")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products                    Product[]
  productVariants             ProductVariant[]
  productAttributeDefinitions ProductAttributeDefinition[]
  orders                      Order[]
  customers                   Customer[]
  reviews                     ProductReview[]

  description    String?
  whatsapp       String?
  shippingFee    Float   @default(0)
  shippingPolicy String?
  isActive       Boolean @default(true)

  // Legacy color fields kept only for backward compatibility.
  // New storefront templates should use their own fixed colors from template folders.
  primaryColor String @default("#2563EB")
  accentColor  String @default("#2ED9B3")

  ownerId String?
  owner   User?   @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  customerUsers User[] @relation("CustomerStoreUsers")

  displayName String?
  tagline     String?

  logoUrl  String?
  coverUrl String?

  contactPhone String?
  contactEmail String?

  city    String?
  area    String?
  address String?

  facebookUrl  String?
  instagramUrl String?
  tiktokUrl    String?
  websiteUrl   String?

  template       StoreTemplate @default(MIZAR_MODERN)
  templateConfig Json?
  productSchema  Json?

  fontPreset   String @default("cairo")
  layoutPreset String @default("modern")

  onboardingCompleted   Boolean             @default(false)
  onboardingCompletedAt DateTime?
  inventoryMovements    InventoryMovement[]

  // New store identity fields
  nameAr           String?
  nameEn           String?
  shortDescription String?
  descriptionAr    String?
  descriptionEn    String?
  fullDescription  String?
  subCategory      String?
  ownerName        String?
  establishedYear  Int?
  faviconUrl       String?
  bannerUrl        String?
  status           StoreStatus @default(OPEN)
  defaultLanguage  String      @default("ar")

  // Phase 1 store settings relations
  contactSettings      StoreContactSettings?
  addressSettings      StoreAddress?
  socialLinks          StoreSocialLink[]
  paymentMethods       StorePaymentMethod[]
  shippingSettings     StoreShippingSettings?
  taxSettings          StoreTaxSettings?
  policies             StorePolicy[]
  seoSettings          StoreSeoSettings?
  notificationSettings StoreNotificationSettings?
  productSettings      StoreProductSettings?
  footerSettings       StoreFooterSettings?
  homepageSettings     StoreHomepageSettings?
  brands               Brand[]
  blogPosts            StoreBlogPost[]
  customerAddresses    CustomerAddress[]
  supportTickets       SupportTicket[]
  newsletterSubscribers NewsletterSubscriber[]

  @@index([ownerId])
  @@index([category])
  @@index([template])
  @@index([status])
  @@index([onboardingCompleted])
}

model StoreContactSettings {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  businessEmail    String?
  supportEmail     String?
  mobileNumber     String?
  whatsappNumber   String?
  landlineNumber   String?
  workingDays      Json?
  workingHours     Json?
  emergencyContact String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreAddress {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  country        String?
  state          String?
  city           String?
  district       String?
  street         String?
  buildingNumber String?
  postalCode     String?
  googleMapsUrl  String?
  latitude       Float?
  longitude      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreSocialLink {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  platform SocialPlatform
  url      String
  isActive Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, platform])
  @@index([storeId])
  @@index([platform])
  @@index([isActive])
}

model StorePaymentMethod {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  type      PaymentMethodType
  isEnabled Boolean           @default(false)
  config    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, type])
  @@index([storeId])
  @@index([type])
  @@index([isEnabled])
}

model StoreShippingSettings {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  shippingCompanies     Json?
  shippingCost          Float   @default(0)
  freeShippingThreshold Float?
  estimatedDeliveryTime String?
  pickupAvailable       Boolean @default(false)
  shippingPolicy        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreTaxSettings {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  pricesIncludeTax             Boolean @default(false)
  taxPercentage                Float?
  commercialRegistrationNumber String?
  taxRegistrationNumber        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StorePolicy {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  type      StorePolicyType
  titleAr   String?
  titleEn   String?
  contentAr String?
  contentEn String?
  isActive  Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, type])
  @@index([storeId])
  @@index([type])
  @@index([isActive])
}

model StoreSeoSettings {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImageUrl      String?
  canonicalUrl    String?
  robotsIndex     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreNotificationSettings {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  emailNotificationsEnabled    Boolean @default(true)
  smsNotificationsEnabled      Boolean @default(false)
  whatsappNotificationsEnabled Boolean @default(false)
  browserNotificationsEnabled  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreProductSettings {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  displaySku             Boolean @default(true)
  displayBrand           Boolean @default(true)
  displayStockQuantity   Boolean @default(false)
  allowReviews           Boolean @default(true)
  allowQuestions         Boolean @default(true)
  allowWishlist          Boolean @default(true)
  allowCompare           Boolean @default(false)
  enableRecentlyViewed   Boolean @default(true)
  enableProductSharing   Boolean @default(true)
  defaultProductsPerPage Int     @default(24)
  weightUnit             String  @default("kg")
  dimensionUnit          String  @default("cm")
  currency               String  @default("EGP")
  language               String  @default("ar")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreFooterSettings {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  aboutStoreAr         String?
  aboutStoreEn         String?
  quickLinks           Json?
  customerServiceLinks Json?
  paymentIcons         Json?
  shippingPartners     Json?
  copyrightText        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreHomepageSettings {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  enableHeroBanner         Boolean @default(true)
  heroBanners              Json?
  enableFeaturedCategories Boolean @default(true)
  featuredCategoryIds      Json?
  enableFeaturedProducts   Boolean @default(true)
  featuredProductIds       Json?
  enableBestSellers        Boolean @default(true)
  enableNewArrivals        Boolean @default(true)
  enableOffers             Boolean @default(true)
  enableBrands             Boolean @default(false)
  enableReviews            Boolean @default(true)
  enableNewsletter         Boolean @default(true)
  enableBlogPreview        Boolean @default(false)
  enableServices           Boolean @default(true)
  services                 Json?
  enableInstagramGallery   Boolean @default(false)
  instagramImages          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name     String
  logoUrl  String?
  website  String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([isActive])
}

model StoreBlogPost {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  titleAr     String?
  titleEn     String?
  slug        String
  excerptAr   String?
  excerptEn   String?
  contentAr   String?
  contentEn   String?
  imageUrl    String?
  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([isPublished])
  @@index([createdAt])
}

model Product {
  id      String @id @default(cuid())
  storeId String

  name             String
  slug             String?
  shortDescription String?
  description      String?
  fullDescription  String?

  price    Float
  stock    Int     @default(0)
  imageUrl String?
  category String?

  status ProductStatus @default(ACTIVE)
  type   ProductType   @default(SIMPLE)

  brand           String?
  supplierName    String?
  countryOfOrigin String?
  warrantyInfo    String?

  tags     Json?
  keywords Json?

  compareAtPrice     Float?
  discountPrice      Float?
  costPrice          Float?
  minSellingPrice    Float?
  maxDiscountPercent Float?
  currency           String  @default("EGP")
  includesTax        Boolean @default(false)
  taxRate            Float?

  reservedStock   Int             @default(0)
  availableStock  Int             @default(0)
  lowStockAlert   Int             @default(5)
  trackInventory  Boolean         @default(true)
  inventoryPolicy InventoryPolicy @default(STOP_WHEN_OUT)

  requiresShipping Boolean @default(true)
  weight           Float?
  length           Float?
  width            Float?
  height           Float?
  packageType      String?
  preparationDays  Int?
  shippingNotes    String?

  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  seoKeywords     Json?

  isFeatured   Boolean @default(false)
  isNewArrival Boolean @default(false)
  isBestSeller Boolean @default(false)
  showOnHome   Boolean @default(false)
  badges       Json?
  campaignIds  Json?

  customFields      Json?
  internalNotes     String?
  externalProductId String?

  ratingAverage Float @default(0)
  ratingCount   Int   @default(0)

  // Legacy flexible fields - kept for compatibility with current code
  attributes Json?
  options    Json?
  variants   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productOptions     ProductOption[]
  productVariants    ProductVariant[]
  orderItems         OrderItem[]
  media              ProductMedia[]
  attachments        ProductAttachment[]
  reviews            ProductReview[]
  inventoryMovements InventoryMovement[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([category])
  @@index([status])
  @@index([type])
  @@index([isFeatured])
  @@index([createdAt])
}

model ProductOption {
  id        String @id @default(cuid())
  productId String
  name      String
  values    Json
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, name])
  @@index([productId])
}

model ProductVariant {
  id        String @id @default(cuid())
  productId String
  storeId   String

  title   String
  sku     String?
  barcode String?

  options Json?

  imageUrl String?

  price          Float
  compareAtPrice Float?
  costPrice      Float?

  weight Float?
  length Float?
  width  Float?
  height Float?

  quantity          Int @default(0)
  reservedQuantity  Int @default(0)
  availableQuantity Int @default(0)
  lowStockAlert     Int @default(5)

  location       String?
  supplierSku    String?
  serialNumber   String?
  batchNumber    String?
  expirationDate DateTime?

  inventoryPolicy InventoryPolicy      @default(STOP_WHEN_OUT)
  status          ProductVariantStatus @default(ACTIVE)
  sortOrder       Int                  @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  media              ProductMedia[]
  attachments        ProductAttachment[]
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, sku])
  @@index([productId])
  @@index([storeId])
  @@index([sku])
  @@index([barcode])
  @@index([status])
}

model ProductMedia {
  id        String  @id @default(cuid())
  productId String
  variantId String?

  type   ProductMediaType
  source MediaSource      @default(UPLOAD)

  url          String
  thumbnailUrl String?
  webpUrl      String?

  sortOrder Int     @default(0)
  isCover   Boolean @default(false)

  altText     String?
  title       String?
  description String?

  width     Int?
  height    Int?
  sizeBytes Int?
  mimeType  String?

  durationSeconds Int?
  displayMode     String?

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([variantId])
  @@index([isCover])
  @@index([sortOrder])
}

model ProductAttachment {
  id        String  @id @default(cuid())
  productId String
  variantId String?

  type ProductAttachmentType @default(OTHER)

  name      String
  url       String
  mimeType  String?
  sizeBytes Int?

  sortOrder         Int     @default(0)
  visibleToCustomer Boolean @default(true)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([variantId])
  @@index([type])
}

model ProductAttributeDefinition {
  id      String  @id @default(cuid())
  storeId String?

  businessType String?
  category     String?

  key     String
  labelAr String
  labelEn String?

  dataType  String
  inputType String @default("text")

  options Json?

  visibleToCustomer Boolean @default(true)
  visibleToMerchant Boolean @default(true)
  internalOnly      Boolean @default(false)

  required   Boolean @default(false)
  searchable Boolean @default(false)
  filterable Boolean @default(false)
  comparable Boolean @default(false)

  defaultValue    Json?
  validationRules Json?
  dependsOn       Json?

  sortOrder Int @default(0)

  store Store? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([businessType])
  @@index([category])
  @@index([key])
}

model ProductReview {
  id         String  @id @default(cuid())
  productId  String
  storeId    String
  customerId String?
  userId     String?
  orderId    String?

  rating Int

  title String?
  body  String?

  displayName String?
  isAnonymous Boolean @default(false)

  verifiedPurchase Boolean @default(false)

  status ReviewStatus @default(PENDING)

  helpfulCount Int @default(0)
  reportCount  Int @default(0)

  merchantReply   String?
  merchantReplyAt DateTime?

  adminReply   String?
  adminReplyAt DateTime?

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User?     @relation("ReviewUser", fields: [userId], references: [id], onDelete: SetNull)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  media ProductReviewMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([storeId])
  @@index([customerId])
  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
}

model ProductReviewMedia {
  id       String @id @default(cuid())
  reviewId String

  type ProductMediaType
  url  String

  thumbnailUrl String?
  sortOrder    Int     @default(0)

  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId])
}

enum InventoryMovementType {
  MANUAL_ADJUSTMENT
  ORDER_CREATED
  ORDER_CANCELLED
  ORDER_RESTORED
  RETURN
  RESTOCK
  DAMAGE
  CORRECTION
}

model InventoryMovement {
  id String @id @default(cuid())

  storeId   String
  productId String
  variantId String?

  type InventoryMovementType

  quantityBefore Int
  quantityChange Int
  quantityAfter  Int

  reason String?
  note   String?

  referenceType String?
  referenceId   String?

  createdByUserId String?

  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdBy User?           @relation("InventoryMovementUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([productId])
  @@index([variantId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model Customer {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  phone     String
  email     String?
  address   String?
  city      String?
  notes     String?
  createdAt DateTime @default(now())

  store   Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders  Order[]
  reviews ProductReview[]

  userId String?
  user   User?   @relation("CustomerUser", fields: [userId], references: [id], onDelete: SetNull)

  addresses      CustomerAddress[]
  supportTickets SupportTicket[]

  @@index([userId])
  @@index([storeId])
}

model CustomerAddress {
  id         String @id @default(cuid())
  storeId    String
  customerId String

  fullName String
  phone    String

  country  String?
  state    String?
  city     String
  district String?
  street   String?
  address  String
  notes    String?

  latitude  Float?
  longitude Float?

  isDefault Boolean @default(false)

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([customerId])
  @@index([isDefault])
}

model SupportTicket {
  id         String @id @default(cuid())
  storeId    String
  customerId String

  subject String
  message String
  status  SupportTicketStatus @default(OPEN)

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model Order {
  id            String      @id @default(cuid())
  storeId       String
  customerId    String?
  total         Float
  status        OrderStatus @default(NEW)
  payment       String      @default("COD")
  paymentMethod String      @default("CASH_ON_DELIVERY")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  subtotalBeforeDiscount Float @default(0)
  productDiscountTotal   Float @default(0)
  subtotalAfterDiscount  Float @default(0)
  shippingFeeSnapshot    Float @default(0)

  store    Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?       @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  reviews  ProductReview[]

  userId String?
  user   User?   @relation("OrderUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?

  quantity Int
  price    Float

  productName  String?
  variantTitle String?
  sku          String?

  unitCost Float?
  profit   Float?
  total    Float?

  originalPrice   Float?
  finalPrice      Float?
  discountAmount  Float  @default(0)
  discountPercent Float  @default(0)
  originalTotal   Float  @default(0)
  discountTotal   Float  @default(0)
  finalTotal      Float  @default(0)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([sku])
}

model User {
  id    String  @id @default(cuid())
  name  String
  email String  @unique
  phone String?

  passwordHash String?
  role         UserRole @default(CUSTOMER)

  firstName    String?
  secondName   String?
  thirdName    String?
  gender       Gender?
  businessType String?

  authProvider    AuthProvider @default(EMAIL)
  googleId        String?      @unique
  avatarUrl       String?
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  acceptedTerms      Boolean   @default(false)
  termsAcceptedAt    DateTime?
  termsVersion       String?
  privacyVersion     String?
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?

  merchantOnboardingCompleted   Boolean   @default(false)
  merchantOnboardingCompletedAt DateTime?
  welcomeSeenAt                 DateTime?

  testimonials   Testimonial[]   @relation("UserTestimonials")
  productReviews ProductReview[] @relation("ReviewUser")

  customerStoreId String?
  customerStore   Store?  @relation("CustomerStoreUsers", fields: [customerStoreId], references: [id], onDelete: SetNull)

  ownedStores Store[] @relation("StoreOwner")

  customers          Customer[]          @relation("CustomerUser")
  orders             Order[]             @relation("OrderUser")
  inventoryMovements InventoryMovement[] @relation("InventoryMovementUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([phone])
  @@index([authProvider])
  @@index([customerStoreId])
  @@index([merchantOnboardingCompleted])
  @@index([createdAt])
}

model Testimonial {
  id String @id @default(cuid())

  merchantId String?
  merchant   User?   @relation("UserTestimonials", fields: [merchantId], references: [id], onDelete: SetNull)

  name         String
  businessType String?
  rating       Int     @default(5)
  message      String

  status     TestimonialStatus @default(PENDING)
  isFeatured Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantId])
  @@index([status])
  @@index([isFeatured])
  @@index([createdAt])
}

model ContactMessage {
  id String @id @default(cuid())

  name    String
  email   String
  phone   String?
  company String?
  subject String
  message String

  status ContactMessageStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([isActive])
}


model NewsletterSubscriber {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  email     String
  source    String?
  status    String   @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, email])
  @@index([storeId])
  @@index([email])
  @@index([status])
  @@index([createdAt])
}
